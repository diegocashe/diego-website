---
/**
 * Layout
 *
 * Thin wrapper around BaseLayout for standard pages (index, cv, projects,
 * design-system). Passes through the most commonly needed SEO props while
 * keeping per-page imports minimal.
 *
 * For blog posts use BlogPostLayout directly — it passes article-specific
 * props (pubDate, tags, ogType) that this wrapper omits.
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?:       string;
  description?: string;
  ogImage?:     string;
  noindex?:     boolean;
  bodyClass?:   string;
}
const { title = 'Diego Castillo · Lead Frontend & Full-Stack Developer', ...rest } = Astro.props;
---

<BaseLayout title={title} {...rest}>
  <slot />
</BaseLayout>
