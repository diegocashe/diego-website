---
import Layout          from '../layouts/Layout.astro';
import SiteNavbar      from '../components/landing/SiteNavbar.astro';
import SiteFooter      from '../components/landing/SiteFooter.astro';
import SkillGroup      from '../components/cv/SkillGroup.astro';
import TimelineItem    from '../components/cv/TimelineItem.astro';
import PublicationCard from '../components/cv/PublicationCard.astro';
import { site }        from '../data/site';
import { skills, experience, education, publications } from '../data/cv';
---

<Layout
  title="CV · Diego Castillo"
  description="Curriculum Vitae de Diego Castillo — Lead Frontend & Full-Stack Developer con 7+ años de experiencia en React, Node.js, TypeScript, AWS y liderazgo técnico."
>
  <SiteNavbar />

  <!-- Hero (unique two-column layout — not using PageHero) -->
  <header class="page-header-dark cv-hero">
    <div class="cv-inner">
      <div class="hero-left">
        <div class="eyebrow-muted">Curriculum Vitae</div>
        <h1><span data-glitch>{site.name}</span><span class="dot">.</span></h1>
        <p class="role">{site.role}</p>
        <p class="summary">
          7+ years architecting high-performance web applications and leading technical teams.
          Scaled engineering departments up to 15 developers. Currently researching
          AI automation in agile development as part of a Master's thesis.
        </p>
      </div>

      <div class="contact-card">
        <div class="contact-label">Contacto</div>
        <ul class="contact-list">
          <li><span class="ci">@</span><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><span class="ci">☎</span><span>{site.phone}</span></li>
          <li><span class="ci">⌖</span><span>{site.location}</span></li>
          <li>
            <span class="ci">in</span>
            <a href={site.linkedin} target="_blank" rel="noopener">
              linkedin.com/in/diegocashe
            </a>
          </li>
        </ul>
        <div class="lang-row">
          <span class="lang-pill">🇪🇸 Spanish — Native</span>
          <span class="lang-pill">🇺🇸 English — Intermediate</span>
        </div>
        <button class="download-btn" id="print-btn">↓ Download PDF</button>
      </div>
    </div>
  </header>

  <main id="main-content" class="cv-main">
    <div class="page-inner cv-sections">

      <!-- 01 Skills -->
      <section>
        <h2 class="sec-title"><span class="num">01</span> Skills</h2>
        <div class="skills-grid">
          {skills.map((g) => <SkillGroup category={g.category} items={g.items} />)}
        </div>
      </section>

      <!-- 02 Experience -->
      <section>
        <h2 class="sec-title"><span class="num">02</span> Experience</h2>
        <div class="timeline">
          {experience.map((job, i) => (
            <TimelineItem
              company={job.company}
              location={job.location}
              role={job.role}
              period={job.period}
              current={job.current}
              last={i === experience.length - 1}
              bullets={job.bullets}
            />
          ))}
        </div>
      </section>

      <!-- 03 Education -->
      <section>
        <h2 class="sec-title"><span class="num">03</span> Education</h2>
        <div class="timeline">
          {education.map((edu, i) => (
            <TimelineItem
              company={edu.institution}
              location={edu.location}
              role={edu.degree}
              focus={edu.focus}
              period={edu.period}
              current={edu.current}
              last={i === education.length - 1}
            />
          ))}
        </div>
      </section>

      <!-- 04 Highlights -->
      <section>
        <h2 class="sec-title"><span class="num">04</span> Highlights</h2>
        <div class="highlights-grid">
          <div class="hl-card">
            <div class="hl-label">Certification</div>
            <p class="hl-text">
              Introducción al Desarrollo de Sistemas Expertos y Lenguaje de Programación PROLOG
            </p>
          </div>
          <div class="hl-card achievement">
            <div class="hl-label">Achievement</div>
            <div class="award-badge">🥉 3rd Place</div>
            <p class="hl-text">
              <strong>Maracaibo Innova</strong> — Pioneered an AI-driven NLP predictive
              sales and management software.
            </p>
          </div>
        </div>
      </section>

      <!-- 05 Publications -->
      <section>
        <h2 class="sec-title"><span class="num">05</span> Publications</h2>
        <div class="pub-list">
          {publications.map((p) => (
            <PublicationCard title={p.title} authors={p.authors} abstract={p.abstract} />
          ))}
        </div>
      </section>

    </div>
  </main>

  <SiteFooter />
</Layout>

<style>
  /* ── CV hero overrides (two-column, wider container) ── */
  .cv-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: start;
  }
  h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(32px, 4vw, 48px);
    letter-spacing: -0.03em;
    color: #fff;
    margin: 14px 0 6px;
    line-height: 1;
  }
  .dot   { color: var(--blue); }
  .role  {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blue);
    margin: 0 0 20px;
  }
  .summary {
    font-size: 14.5px;
    line-height: 1.65;
    color: rgba(255,255,255,0.5);
    max-width: 540px;
    margin: 0;
  }

  /* ── Contact card ── */
  .contact-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 24px;
    min-width: 260px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex-shrink: 0;
  }
  .contact-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
  }
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .contact-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12.5px;
    color: rgba(255,255,255,0.6);
  }
  .ci {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    width: 16px;
    text-align: center;
    color: rgba(255,255,255,0.25);
    flex-shrink: 0;
  }
  .contact-list a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color 0.15s;
  }
  .contact-list a:hover { color: #fff; }
  .lang-row   { display: flex; flex-direction: column; gap: 6px; }
  .lang-pill  {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: rgba(255,255,255,0.35);
  }
  .download-btn {
    appearance: none;
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: var(--blue);
    color: #fff;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 13px;
    padding: 10px 16px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .download-btn:hover { background: var(--blue-d); }

  /* ── Main ── */
  .cv-main { background: var(--bg); padding: 64px 40px 96px; }
  .cv-sections { display: flex; flex-direction: column; gap: 64px; }

  /* ── Section title ── */
  .sec-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 28px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .sec-title::after { content: ''; flex: 1; height: 1px; background: var(--line); }
  .num { font-family: 'JetBrains Mono', monospace; color: var(--blue); }

  /* ── Skills grid ── */
  .skills-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

  /* ── Highlights ── */
  .highlights-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .hl-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .hl-card.achievement { border-color: var(--blue); background: var(--tint); }
  .hl-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .hl-card.achievement .hl-label { color: var(--blue-d); }
  .award-badge { font-size: 22px; font-weight: 800; letter-spacing: -0.01em; color: var(--ink); }
  .hl-text  { font-size: 13.5px; line-height: 1.55; color: var(--ink-2); margin: 0; }

  /* ── Publications ── */
  .pub-list { display: flex; flex-direction: column; gap: 16px; }

  /* ── Timeline container ── */
  .timeline { display: flex; flex-direction: column; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .cv-inner       { grid-template-columns: 1fr; }
    .contact-card   { min-width: unset; }
    .skills-grid    { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .cv-main        { padding: 48px 24px 72px; }
    .skills-grid    { grid-template-columns: 1fr; }
    .highlights-grid{ grid-template-columns: 1fr; }
  }

  /* ── Print ── */
  @media print {
    :global(header.navbar), :global(footer) { display: none !important; }
    .cv-hero   { background: #fff !important; padding: 24px 0 20px; }
    .cv-main   { padding: 20px 0; }
    h1, .role, .summary, .contact-list li, .contact-list a { color: #000 !important; }
    .download-btn { display: none !important; }
  }
</style>

<script>
  import '../scripts/glitch';
  document.getElementById('print-btn')?.addEventListener('click', () => window.print());
</script>
