---
import Layout from '../layouts/Layout.astro';
import SiteNavbar     from '../components/landing/SiteNavbar.astro';
import HeroSection    from '../components/landing/HeroSection.astro';
import StatsSection   from '../components/landing/StatsSection.astro';
import ProjectsSection from '../components/landing/ProjectsSection.astro';
import ContactCTA     from '../components/landing/ContactCTA.astro';
import SiteFooter     from '../components/landing/SiteFooter.astro';
---

<Layout
  title="Diego Castillo · Programador Full-Stack"
  description="Lead Frontend & Full-Stack Developer con 7+ años construyendo aplicaciones web de alto rendimiento. Especialista en React, Node.js, TypeScript y arquitectura de software."
>
  <SiteNavbar />
  <main id="main-content">
    <HeroSection />
    <StatsSection />
    <ProjectsSection />
    <ContactCTA />
  </main>
  <SiteFooter />
</Layout>
