---
/**
 * PostCard
 *
 * Blog post preview card used in the /blog listing grid.
 *
 * @prop {string}   slug        - URL slug for the post link
 * @prop {string}   title       - Post headline
 * @prop {string}   description - One-line summary shown under the title
 * @prop {Date}     pubDate     - Publication date (formatted as "DD MMM YYYY")
 * @prop {string[]} tags        - Topic tags rendered as mono chips
 * @prop {number}   readTime    - Estimated read time in minutes
 * @prop {boolean}  [featured]  - Larger, full-width treatment for hero post
 */
interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  readTime: number;
  featured?: boolean;
}

const { slug, title, description, pubDate, tags, readTime, featured = false } = Astro.props;

const fmt = new Intl.DateTimeFormat('es-MX', { day: '2-digit', month: 'short', year: 'numeric' });
const dateStr = fmt.format(pubDate);
---

<a href={`/blog/${slug}`} class:list={['card', { featured }]}>
  <div class="cover" aria-hidden="true">
    <span class="first-tag">{tags[0]}</span>
  </div>

  <div class="body">
    <div class="meta">
      <time datetime={pubDate.toISOString()}>{dateStr}</time>
      <span class="sep">·</span>
      <span>{readTime} min</span>
    </div>

    <h2>{title}</h2>
    <p>{description}</p>

    <div class="tags">
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.18s, transform 0.18s;
  }
  .card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-3px);
  }

  /* ── Cover strip ── */
  .cover {
    height: 120px;
    background: linear-gradient(135deg, var(--ink) 0%, #1f4fd6 100%);
    display: flex;
    align-items: flex-end;
    padding: 14px 18px;
    position: relative;
    overflow: hidden;
  }
  .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      rgba(255,255,255,0.02) 0px,
      rgba(255,255,255,0.02) 1px,
      transparent 1px,
      transparent 12px
    );
  }
  .first-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    position: relative;
  }
  .featured .cover { height: 180px; }

  /* ── Body ── */
  .body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--ink-3);
  }
  .sep { opacity: 0.4; }

  h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--ink);
    margin: 0;
  }
  .featured h2 { font-size: 22px; }

  p {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    flex: 1;
  }

  /* ── Tags ── */
  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    font-weight: 500;
    padding: 3px 8px;
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--ink-3);
  }
</style>
