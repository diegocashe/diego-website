---
import Layout      from '../layouts/Layout.astro';
import SiteNavbar  from '../components/landing/SiteNavbar.astro';
import SiteFooter  from '../components/landing/SiteFooter.astro';
import PageHero    from '../components/shared/PageHero.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import { projects, categories } from '../data/projects';

if (import.meta.env.PUBLIC_FEATURE_PROJECTS !== 'true') return Astro.redirect('/', 302);

const stats = [
  { value: '9+',  label: 'proyectos destacados' },
  { value: '7+',  label: 'años de experiencia'  },
  { value: '4',   label: 'industrias'            },
  { value: '15+', label: 'tecnologías'           },
] as const;
---

<Layout
  title="Proyectos · Diego Castillo"
  description="Portfolio de proyectos en producción: ERPs, plataformas LMS, dashboards en tiempo real, herramientas con IA y sistemas Web3."
>
  <SiteNavbar />

  <PageHero
    eyebrow="Trabajo seleccionado"
    title="Proyectos"
    description="Aplicaciones en producción: ERPs, plataformas LMS, dashboards en tiempo real, herramientas con IA y sistemas Web3. Cada uno resolvió un problema real."
  >
    <div class="hero-stats">
      {stats.map((s) => (
        <div class="hstat">
          <div class="hstat-v">{s.value}</div>
          <div class="hstat-l">{s.label}</div>
        </div>
      ))}
    </div>
  </PageHero>

  <main id="main-content" class="main">
    <div class="page-inner">

      <div class="filter-bar" id="filter-bar">
        {categories.map((cat) => (
          <button
            class:list={['filter-btn', { active: cat === 'All' }]}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="count-row">
        <span id="count-label">{projects.length} proyectos</span>
      </div>

      <div class="grid" id="projects-grid">
        {projects.map((p) => (
          <ProjectCard
            slug={p.slug}
            title={p.title}
            description={p.description}
            tags={p.tags}
            category={p.category}
            status={p.status}
            year={p.year}
            company={p.company}
            gradient={p.gradient}
          />
        ))}
      </div>

      <div class="empty" id="empty-state" style="display:none;">
        <span class="empty-icon">✦</span>
        <p>No hay proyectos en esta categoría todavía.</p>
      </div>

    </div>
  </main>

  <SiteFooter />
</Layout>

<style>
  /* ── Hero extras (slot content) ── */
  .hero-stats {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
    margin-top: 32px;
  }
  .hstat-v {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 800;
    font-size: 28px;
    letter-spacing: -0.04em;
    color: var(--blue);
    line-height: 1;
  }
  .hstat-l {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-top: 5px;
  }

  /* ── Main ── */
  .main {
    background: var(--bg);
    padding: 48px 40px 96px;
  }
  .main .page-inner {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* ── Filter bar ── */
  .filter-bar {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .filter-btn {
    appearance: none;
    border: 1px solid var(--line);
    background: var(--paper);
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: var(--ink-2);
    padding: 8px 16px;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-btn:hover { border-color: var(--ink-3); color: var(--ink); }
  .filter-btn.active { background: var(--ink); border-color: var(--ink); color: #fff; }

  .count-row {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.08em;
  }

  /* ── Grid ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  /* ── Empty state ── */
  .empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 80px 0;
    color: var(--ink-3);
  }
  .empty-icon { font-size: 28px; opacity: 0.3; }
  .empty p {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    margin: 0;
  }

  @media (max-width: 960px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
    .main { padding: 36px 24px 72px; }
    .hero-stats { gap: 24px; }
  }
</style>

<script>
  const filterBar  = document.getElementById('filter-bar')!;
  const grid       = document.getElementById('projects-grid')!;
  const emptyState = document.getElementById('empty-state')!;
  const countLabel = document.getElementById('count-label')!;
  const cards      = Array.from(grid.querySelectorAll<HTMLElement>('[data-category]'));

  function applyFilter(category: string) {
    filterBar.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset['category'] === category);
    });

    let visible = 0;
    cards.forEach((card) => {
      const match = category === 'All' || card.dataset['category'] === category;
      card.classList.toggle('hidden', !match);
      if (match) visible++;
    });

    countLabel.textContent = `${visible} proyecto${visible !== 1 ? 's' : ''}`;
    emptyState.style.display = visible === 0 ? 'flex' : 'none';
  }

  filterBar.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.filter-btn');
    if (btn?.dataset['category']) applyFilter(btn.dataset['category']);
  });
</script>
