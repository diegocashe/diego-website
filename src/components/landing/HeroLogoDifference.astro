<section class="hero-logo-diff">
  <div class="inner">
    <div class="logo-container" aria-hidden="true">
      <div class="logo-background"></div>

      <div class="logo-text">
        <span>diego</span><br />
        <span>castillo</span><span class="dot"></span>
      </div>

      <div class="logo-shadow"></div>
    </div>
  </div>
</section>

<style>
  .hero-logo-diff .inner {
    display: flex;
    justify-content: center;
    padding: 4rem 2rem;
  }

  .hero-logo-diff .logo-container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-size: 8rem;
  }

  .hero-logo-diff .logo-background {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: var(--ink);
    width: 4ch;
    height: 4ch;
    z-index: 1;
  }

  /* mix-blend-mode en el padre:
     blends todo el elemento contra lo que está detrás.
     Los spans heredan el contexto pero no pueden anularlo individualmente
     porque logo-text crea un stacking context aislado */
  .hero-logo-diff .logo-text {
    position: relative;
    z-index: 2;
    width: max-content;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.05em;
    white-space: nowrap;
    margin: 0;
    user-select: none;
    background-image: linear-gradient(#ffffff, #ffffff);
    background-repeat: no-repeat;
    background-position: 50% 50%;
    background-color: var(--ink);
    -webkit-text-fill-color: transparent;
    background-size: var(--bandW) var(--bandH);
    color: transparent;
    background-clip: text;
    -webkit-background-clip: text;
    background-color: var(--ink);
    mix-blend-mode: difference;
  }

  .hero-logo-diff .dot {
    background-color: var(--blue);
    display: inline-block;
    height: 1.3rem;
    width: 1.3rem;
    border-radius: 5px;
    mix-blend-mode: normal;
    animation: dot-pulse 2s infinite;
  }

  .hero-logo-diff .logo-shadow {
    position: absolute;
    inset: 10% -5%;
    background: var(--blue);
    border-radius: 28px;
    filter: blur(48px);
    opacity: 0.14;
    z-index: -1;
  }

  @keyframes dot-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(31, 138, 91, 0.45); }
    70%  { box-shadow: 0 0 0 8px rgba(31, 138, 91, 0); }
    100% { box-shadow: 0 0 0 0 rgba(31, 138, 91, 0); }
  }
</style>
