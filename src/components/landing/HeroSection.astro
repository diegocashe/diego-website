---
import Button from '../ds/atoms/Button.astro';
---

<section class="hero">
  <div class="inner">

    <!-- Left: text -->
    <div class="content">
      <div class="eyebrow">
        <span class="dot-pulse"></span>
        Programador Full-Stack
      </div>

      <h1>
        Construyo producto,<br />
        de la idea al deploy<span class="blue-dot">.</span>
      </h1>

      <p>
        Diseño sistemas claros, escribo código que se mantiene
        y envío rápido. Disponible para proyectos freelance.
      </p>

      <div class="ctas">
        <Button variant="ink" size="lg">
          Ver proyectos <span class="arr">→</span>
        </Button>
        <Button variant="out" size="lg">Descargar CV</Button>
      </div>

      <div class="stack-tags">
        <span class="tag">React</span>
        <span class="tag">TypeScript</span>
        <span class="tag">Node.js</span>
        <span class="tag">PostgreSQL</span>
      </div>
    </div>

    <!-- Right: brand mark -->
    <div class="mark-wrap" aria-hidden="true">
      <div class="mark">
        <div class="wm stack rev" style="font-size:clamp(28px,4.5vw,52px);">
          <span>diego</span>
          <span>castillo<span class="dot">.</span></span>
        </div>
      </div>
      <div class="mark-glow"></div>
    </div>

  </div>
</section>

<style>
  .hero {
    background: #fff;
    padding: 80px 40px 96px;
    border-bottom: 1px solid var(--line);
  }
  .inner {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 64px;
    align-items: center;
  }

  /* ── Eyebrow ── */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--blue-d);
    margin-bottom: 20px;
  }
  .dot-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ok);
    flex: none;
    box-shadow: 0 0 0 0 rgba(31, 138, 91, 0.4);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0   rgba(31,138,91,0.45); }
    70%  { box-shadow: 0 0 0 8px rgba(31,138,91,0);    }
    100% { box-shadow: 0 0 0 0   rgba(31,138,91,0);    }
  }

  /* ── Headline ── */
  h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(32px, 4.5vw, 54px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0 0 20px;
  }
  .blue-dot { color: var(--blue); }

  p {
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-2);
    max-width: 440px;
    margin: 0 0 32px;
  }

  /* ── CTAs ── */
  .ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  /* ── Stack tags ── */
  .stack-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    font-weight: 500;
    padding: 5px 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink-2);
  }

  /* ── Brand mark ── */
  .mark-wrap {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .mark {
    width: min(380px, 100%);
    aspect-ratio: 1;
    background: var(--ink);
    border-radius: 28px;
    display: grid;
    place-items: start;
    align-items: center;
    padding-left: 13%;
    position: relative;
    z-index: 1;
  }
  .mark .wm { line-height: 0.94; }
  .mark-glow {
    position: absolute;
    inset: 10% -5%;
    background: var(--blue);
    border-radius: 28px;
    filter: blur(48px);
    opacity: 0.14;
    z-index: 0;
  }

  @media (max-width: 900px) {
    .inner { grid-template-columns: 1fr; }
    .mark-wrap { display: none; }
    h1 { font-size: clamp(30px, 8vw, 48px); }
  }
  @media (max-width: 640px) {
    .hero { padding: 56px 24px 72px; }
  }
</style>
