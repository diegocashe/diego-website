---
import Button from '../ds/atoms/Button.astro';
import BadgePill from '../ds/atoms/BadgePill.astro';
import { featuredProjects } from '../../data/projects';
---

<section class="projects" id="trabajo">
  <div class="inner">

    <div class="sec-header">
      <div>
        <div class="eyebrow">Trabajo seleccionado</div>
        <h2>Proyectos recientes</h2>
      </div>
      <Button variant="out"><a href="/projects" class="link">Ver todos →</a></Button>
    </div>

    <div class="grid">
      {featuredProjects.map((p) => (
        <article class="card">
          <div class="cover" style={`background:${p.gradient}`}>
            <div class="wm inline rev" style="font-size:14px;position:absolute;left:20px;bottom:16px;">
              diego castillo<span class="dot" style="color:#fff">.</span>
            </div>
          </div>
          <div class="body">
            <div class="meta">
              <BadgePill variant={p.status === 'delivered' ? 'ok' : 'blue'} label={p.status === 'delivered' ? 'Entregado' : 'En curso'} />
            </div>
            <h3>{p.title}</h3>
            <p>{p.description}</p>
            <div class="stack-row">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <Button variant="out" size="sm"><a href={`/projects#${p.slug}`} class="link">Ver caso →</a></Button>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .projects {
    background: #fff;
    padding: 48px 20px;
    border-bottom: 1px solid var(--line);
  }
  .inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .link { color: inherit; text-decoration: none; }

  .sec-header {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-h2);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    color: var(--ink);
  }

  /* ── Cards grid: 1 col on mobile ── */
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
  }
  .card {
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.18s, transform 0.18s;
  }
  .card:hover { box-shadow: var(--shadow); transform: translateY(-3px); }

  .cover { height: 140px; position: relative; }

  .body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 12px;
  }
  .meta { display: flex; }
  h3 { font-size: var(--text-h3); font-weight: 700; letter-spacing: var(--tracking-card); margin: 0; color: var(--ink); }
  p  { font-size: var(--text-body-sm); color: var(--ink-2); line-height: var(--leading-body-sm); margin: 0; flex: 1; }

  .stack-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    padding: 4px 9px;
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--ink-2);
  }

  /* ── Tablet ── */
  @media (min-width: 768px) {
    .projects { padding: 60px 32px; }
    .sec-header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 40px;
    }
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Desktop ── */
  @media (min-width: 1024px) {
    .projects { padding: 80px 40px; }
    .grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
