---
/**
 * ProjectCard
 *
 * Card used in the /projects grid. Carries a `data-category` attribute
 * so the client-side filter script can show/hide it without re-rendering.
 *
 * @prop {string}   slug        - Used for future detail page links
 * @prop {string}   title
 * @prop {string}   description
 * @prop {string[]} tags        - Tech stack chips
 * @prop {string}   category    - Filter key (also shown in cover)
 * @prop {'delivered'|'in-progress'} status
 * @prop {number}   year
 * @prop {string}   company
 * @prop {string}   gradient    - CSS gradient for the cover strip
 */
interface Props {
  slug:        string;
  title:       string;
  description: string;
  tags:        readonly string[];
  category:    string;
  status:      'delivered' | 'in-progress';
  year:        number;
  company:     string;
  gradient:    string;
}
const { slug, title, description, tags, category, status: projectStatus, year, company, gradient } = Astro.props;
const statusLabel = projectStatus === 'delivered' ? 'Entregado' : 'En curso';
---

<article class="card" data-category={category} data-slug={slug}>
  <div class="cover" style={`background:${gradient}`}>
    <span class="cover-cat">{category}</span>
    <span class="cover-year">{year}</span>
  </div>

  <div class="body">
    <div class="meta-row">
      <span class:list={['status', projectStatus]}>
        <span class="status-dot"></span>
        {statusLabel}
      </span>
      <span class="company">{company}</span>
    </div>

    <h2>{title}</h2>
    <p>{description}</p>

    <div class="tags">
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </div>
</article>

<style>
  .card {
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    background: var(--paper);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.18s, transform 0.18s;
  }
  .card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-3px);
  }
  .card.hidden { display: none; }

  /* ── Cover ── */
  .cover {
    height: 130px;
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 14px 16px;
    overflow: hidden;
  }
  .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      rgba(255,255,255,0.025) 0px,
      rgba(255,255,255,0.025) 1px,
      transparent 1px,
      transparent 14px
    );
  }
  .cover-cat,
  .cover-year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    position: relative;
  }
  .cover-cat  { color: rgba(255,255,255,0.45); }
  .cover-year { color: rgba(255,255,255,0.25); }

  /* ── Body ── */
  .body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11.5px;
    font-weight: 700;
  }
  .status.delivered  { color: var(--ok); }
  .status.in-progress { color: var(--blue); }
  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }
  .company {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 15.5px;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--ink);
    margin: 0;
  }
  p {
    font-size: 13px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    flex: 1;
  }
  .tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    font-weight: 500;
    padding: 3px 8px;
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--ink-3);
  }
</style>
