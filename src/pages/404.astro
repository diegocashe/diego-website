---
import Layout from '../layouts/Layout.astro';
import SiteNavbar from '../components/landing/SiteNavbar.astro';
import SiteFooter from '../components/landing/SiteFooter.astro';
---

<Layout
  title="404 · Página no encontrada"
  description="Esta página no existe. Vuelve al inicio o explora el resto del sitio."
  noindex={true}
  bodyClass="page-404"
>
  <SiteNavbar />
  <main id="main-content" class="nf-main">
    <section class="not-found">

      <div class="nf-bg-num" aria-hidden="true">404</div>

      <div class="nf-inner">
        <p class="eyebrow nf-eyebrow">Error · 404</p>

        <h1 class="nf-heading">
          Página no<br />encontrada<span class="blue-dot">.</span>
        </h1>

        <p class="nf-desc">
          La ruta que buscas no existe o fue movida.<br />
          Nada está roto — solo perdido.
        </p>

        <div class="nf-ctas">
          <a href="/" class="btn btn-ink btn-lg">
            Ir al inicio <span class="arr">→</span>
          </a>
          <a href="/projects" class="btn btn-out btn-lg">
            Ver proyectos
          </a>
        </div>

        <div class="nf-tags" aria-hidden="true">
          <span class="nf-tag">HTTP 404</span>
          <span class="nf-tag">Not Found</span>
          <span class="nf-tag">¯\_(ツ)_/¯</span>
        </div>
      </div>

    </section>
  </main>
  <SiteFooter />
</Layout>

<style>
  /* Flex column layout so main fills the gap between navbar and footer */
  :global(body.page-404) {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .nf-main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .not-found {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }

  /* Ghost "404" behind content */
  .nf-bg-num {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(160px, 28vw, 400px);
    line-height: 1;
    letter-spacing: var(--tracking-tighter);
    color: var(--line-2);
    user-select: none;
    pointer-events: none;
    z-index: 0;
  }

  .nf-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: var(--max-w-prose);
    width: 100%;
    padding: 80px clamp(1.5rem, 5vw, 40px);
  }

  .nf-eyebrow {
    margin-bottom: 24px;
  }

  .nf-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-display);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: 0 0 24px;
  }

  .blue-dot { color: var(--blue); }

  .nf-desc {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--ink-2);
    margin: 0 0 40px;
  }

  .nf-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 36px;
  }

  .btn {
    appearance: none;
    border: 1px solid transparent;
    border-radius: 10px;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: -0.01em;
    padding: 11px 18px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    transition: 0.15s ease;
    line-height: 1;
    white-space: nowrap;
    text-decoration: none;
  }
  .btn:active { transform: translateY(1px); }

  .btn-ink       { background: var(--ink); color: #fff; }
  .btn-ink:hover { background: #222a37; }

  .btn-out       { background: #fff; color: var(--ink); border-color: var(--line); }
  .btn-out:hover { border-color: var(--ink-3); background: #fafbfc; }

  .btn-lg { padding: 14px 24px; font-size: 15px; border-radius: 12px; }

  .arr { font-size: 15px; line-height: 0; }

  .nf-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .nf-tag {
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: 500;
    padding: 5px 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink-3);
  }

  @media (max-width: 640px) {
    .nf-inner  { padding: 60px 24px; }
    .nf-heading { font-size: clamp(32px, 10vw, 48px); }
    .nf-bg-num  { font-size: clamp(120px, 40vw, 200px); }
  }
</style>
