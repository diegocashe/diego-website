---
/**
 * /design-system
 *
 * Design system reference page. Imports and composes all eight section
 * components. Add a new section by creating a component in
 * `src/components/ds/sections/` and dropping it here.
 */
import Layout from '../layouts/Layout.astro';
import LogoVariations    from '../components/ds/sections/LogoVariations.astro';
import TokensSection     from '../components/ds/sections/TokensSection.astro';
import TypographySection from '../components/ds/sections/TypographySection.astro';
import ButtonsSection    from '../components/ds/sections/ButtonsSection.astro';
import FormsSection      from '../components/ds/sections/FormsSection.astro';
import BadgesSection     from '../components/ds/sections/BadgesSection.astro';
import NavigationSection from '../components/ds/sections/NavigationSection.astro';
import CardsSection      from '../components/ds/sections/CardsSection.astro';
import FeedbackSection   from '../components/ds/sections/FeedbackSection.astro';
---

<Layout title="Wordmark UI Kit · Diego Castillo" bodyClass="ds-bg">
  <div class="wrap">

    <div class="pagehead">
      <div>
        <div class="eyebrow">Sistema · diego castillo.</div>
        <h1>Wordmark UI Kit</h1>
      </div>
      <p>
        Componentes web con el ADN del logotipo: Manrope, minúsculas,
        tinta + azul y el <b style="color:var(--blue)">punto</b> como acento recurrente.
      </p>
    </div>

    <LogoVariations />
    <TokensSection />
    <TypographySection />
    <ButtonsSection />
    <FormsSection />
    <BadgesSection />
    <NavigationSection />
    <CardsSection />
    <FeedbackSection />

    <div class="footer">
      Wordmark UI Kit · Manrope + tinta + azul · el punto como acento.
    </div>

  </div>
</Layout>
